{
  "name": "shuttle-iac",
  "displayName": "Shuttle IaC",
  "description": "Schema-aware completion and validation for Shuttle IaC YAML files (hosts.yaml, services/*, dns.yml, orchestrator.yaml), plus scaffolding and check/plan commands — backed by the `shuttle` CLI.",
  "version": "0.2.0",
  "publisher": "neikow",
  "license": "SEE LICENSE IN ../../LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/neikow/shuttle.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shuttle.scaffoldService",
        "title": "Scaffold Service…",
        "category": "Shuttle"
      },
      {
        "command": "shuttle.addHost",
        "title": "Add Host…",
        "category": "Shuttle"
      },
      {
        "command": "shuttle.addDnsProvider",
        "title": "Add DNS Provider…",
        "category": "Shuttle"
      },
      {
        "command": "shuttle.addCertificate",
        "title": "Add Certificate…",
        "category": "Shuttle"
      },
      {
        "command": "shuttle.check",
        "title": "Check (validate repo)",
        "category": "Shuttle"
      },
      {
        "command": "shuttle.plan",
        "title": "Plan (preview changes)",
        "category": "Shuttle"
      }
    ],
    "configuration": {
      "title": "Shuttle",
      "properties": {
        "shuttle.path": {
          "type": "string",
          "default": "shuttle",
          "description": "Path to the `shuttle` binary used for CLI commands (scaffold, check, plan). Must be on PATH, or an absolute path."
        },
        "shuttle.lsp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Run the Shuttle language server for IaC YAML files."
        },
        "shuttle.lsp.path": {
          "type": "string",
          "default": "shuttle",
          "description": "Path to the `shuttle` binary used to run `shuttle lsp` (must be on PATH, or an absolute path)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.84.0",
    "typescript": "^5.4.0"
  }
}
