#!/usr/bin/env bash
#
# Shuttle installer — verifies and installs the `shuttle` binary.
#
#   curl -sSfL https://neikow.github.io/shuttle/install | bash
#
# It downloads the release archive for your OS/arch, verifies the published
# SHA-256 checksum (always), verifies the keyless cosign signature when cosign is
# installed, then installs the binary.
#
# Configuration (environment variables):
#   SHUTTLE_VERSION      Version to install, without a leading "v" (default: latest release).
#   SHUTTLE_INSTALL_DIR  Install directory (default: /usr/local/bin).
#   SHUTTLE_OS           Override OS detection (linux | darwin).
#   SHUTTLE_ARCH         Override arch detection (amd64 | arm64).
#   SHUTTLE_NO_VERIFY    Set to 1 to skip the cosign signature check (checksum still enforced).
#
# Examples:
#   curl -sSfL https://neikow.github.io/shuttle/install | SHUTTLE_VERSION=0.3.0 bash
#   curl -sSfL https://neikow.github.io/shuttle/install | SHUTTLE_INSTALL_DIR="$HOME/.local/bin" bash
#
set -euo pipefail

REPO="neikow/shuttle"
INSTALL_DIR="${SHUTTLE_INSTALL_DIR:-/usr/local/bin}"

# Logs go to stderr so this stays pipe-to-bash friendly.
log() { printf '==> %s\n' "$*" >&2; }
err() { printf 'error: %s\n' "$*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || err "required command not found: $1"; }

need curl
need tar

# ── Detect platform ──────────────────────────────────────────────────────────
os="${SHUTTLE_OS:-$(uname -s | tr '[:upper:]' '[:lower:]')}"
arch="${SHUTTLE_ARCH:-$(uname -m)}"
case "$arch" in
  x86_64 | amd64) arch="amd64" ;;
  aarch64 | arm64) arch="arm64" ;;
  *) err "unsupported architecture: $arch (override with SHUTTLE_ARCH=amd64|arm64)" ;;
esac
case "$os" in
  linux | darwin) ;;
  *) err "unsupported OS: $os (Shuttle ships linux and darwin builds)" ;;
esac

# ── Resolve version ──────────────────────────────────────────────────────────
version="${SHUTTLE_VERSION:-}"
if [ -z "$version" ]; then
  log "resolving latest release…"
  version="$(curl -sSfL "https://api.github.com/repos/$REPO/releases/latest" \
    | grep '"tag_name"' | head -1 | sed -E 's/.*"v?([^"]+)".*/\1/')"
fi
version="${version#v}"
[ -n "$version" ] || err "could not determine a version (set SHUTTLE_VERSION, or the GitHub API may be rate-limited)"

base="https://github.com/$REPO/releases/download/v$version"
archive="shuttle_${version}_${os}_${arch}.tar.gz"
log "installing shuttle $version ($os/$arch)"

# ── Download ─────────────────────────────────────────────────────────────────
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
curl -sSfL "$base/$archive" -o "$tmp/$archive" || err "download failed: $base/$archive"
curl -sSfL "$base/checksums.txt" -o "$tmp/checksums.txt" || err "download failed: $base/checksums.txt"

# ── Verify cosign signature (best effort) ────────────────────────────────────
if [ "${SHUTTLE_NO_VERIFY:-0}" != "1" ] && command -v cosign >/dev/null 2>&1; then
  curl -sSfL "$base/checksums.txt.pem" -o "$tmp/checksums.txt.pem"
  curl -sSfL "$base/checksums.txt.sig" -o "$tmp/checksums.txt.sig"
  cosign verify-blob \
    --certificate "$tmp/checksums.txt.pem" \
    --signature "$tmp/checksums.txt.sig" \
    --certificate-identity-regexp "https://github.com/$REPO/.*" \
    --certificate-oidc-issuer "https://token.actions.githubusercontent.com" \
    "$tmp/checksums.txt" >/dev/null 2>&1 || err "cosign signature verification failed"
  log "cosign signature verified"
else
  log "cosign not found — skipping signature check (checksum still enforced). Install cosign to verify release provenance."
fi

# ── Verify checksum ──────────────────────────────────────────────────────────
want="$(awk -v f="$archive" '$2 == f {print $1}' "$tmp/checksums.txt")"
[ -n "$want" ] || err "no checksum listed for $archive"
if command -v sha256sum >/dev/null 2>&1; then
  got="$(sha256sum "$tmp/$archive" | awk '{print $1}')"
else
  got="$(shasum -a 256 "$tmp/$archive" | awk '{print $1}')"
fi
[ "$want" = "$got" ] || err "checksum mismatch for $archive"
log "checksum verified"

# ── Install ──────────────────────────────────────────────────────────────────
tar -xzf "$tmp/$archive" -C "$tmp" shuttle
dest="$INSTALL_DIR/shuttle"
if mkdir -p "$INSTALL_DIR" 2>/dev/null && [ -w "$INSTALL_DIR" ]; then
  install -m 0755 "$tmp/shuttle" "$dest"
else
  log "elevating with sudo to write $INSTALL_DIR"
  need sudo
  sudo install -d -m 0755 "$INSTALL_DIR"
  sudo install -m 0755 "$tmp/shuttle" "$dest"
fi

log "installed shuttle $version → $dest"
"$dest" version 2>/dev/null || true
case ":$PATH:" in
  *":$INSTALL_DIR:"*) ;;
  *) log "note: $INSTALL_DIR is not on your PATH — add it to run 'shuttle' directly" ;;
esac
